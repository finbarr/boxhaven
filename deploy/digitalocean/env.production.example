ACME_EMAIL=admin@example.com

BOXHAVEN_APP_HOST=app.boxhaven.dev
BOXHAVEN_API_HOST=api.boxhaven.dev
BOXHAVEN_PREVIEW_BASE_DOMAIN=at.boxhaven.dev
BOXHAVEN_PREVIEW_TARGET_PORT=80
BOXHAVEN_PREVIEW_PROXY_TIMEOUT_SECONDS=30
BOXHAVEN_METRICS_BEARER_TOKEN=replace-with-a-random-metrics-token
BOXHAVEN_APP_URL=https://app.boxhaven.dev
BOXHAVEN_API_URL=https://api.boxhaven.dev
BETTER_AUTH_URL=https://api.boxhaven.dev/v1/auth
BETTER_AUTH_TRUSTED_ORIGINS=https://app.boxhaven.dev,https://api.boxhaven.dev
BOXHAVEN_BACKEND_CORS_ORIGINS=https://app.boxhaven.dev,https://api.boxhaven.dev
BETTER_AUTH_SECRET=replace-with-a-random-secret-at-least-32-bytes
BOXHAVEN_SIGNUP_MODE=invite
BOXHAVEN_SIGNUP_ALLOWED_DOMAINS=
BOXHAVEN_SIGNUP_INVITE_CODES=replace-with-one-or-more-comma-separated-invite-codes
BOXHAVEN_MAX_MACHINES_PER_USER=3
BOXHAVEN_MAX_MACHINES_TOTAL=100
BOXHAVEN_MAINTENANCE_INTERVAL_SECONDS=60
BOXHAVEN_IDLE_MACHINE_TTL_HOURS=72
BOXHAVEN_STALE_CREATE_TTL_SECONDS=1800
BOXHAVEN_BACKEND_LOG_REQUESTS=1
BOXHAVEN_BACKEND_TRUST_PROXY=1
BOXHAVEN_AUTH_RATE_LIMIT_WINDOW_SECONDS=60
BOXHAVEN_AUTH_RATE_LIMIT_MAX=30
BOXHAVEN_CREATE_RATE_LIMIT_WINDOW_SECONDS=600
BOXHAVEN_CREATE_RATE_LIMIT_MAX=10

BOXHAVEN_BACKEND_PROVIDER=digitalocean
DIGITALOCEAN_ACCESS_TOKEN=dop_v1_example
DIGITALOCEAN_REGION=nyc3
DIGITALOCEAN_SIZE=s-2vcpu-4gb-amd
DIGITALOCEAN_IMAGE=ubuntu-24-04-x64
DIGITALOCEAN_TAGS=boxhaven
BOXHAVEN_REMOTE_IMAGE=
BOXHAVEN_REMOTE_IMAGE_REF=
BOXHAVEN_REMOTE_IMAGE_NAME=
BOXHAVEN_REMOTE_IMAGE_BUILT_AT=
DIGITALOCEAN_VPC_UUID=

# Image-builder SSH only. Normal user VMs use boxhaven SSH certificates, not
# DigitalOcean account SSH keys.
DIGITALOCEAN_SSH_KEYS=
BOXHAVEN_IMAGE_BUILDER_SSH_PUBLIC_KEY=

BOXHAVEN_BACKUP_RETENTION_DAYS=14
