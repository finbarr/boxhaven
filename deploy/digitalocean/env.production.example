ACME_EMAIL=admin@example.com

BOXHAVEN_APP_HOST=app.boxhaven.dev
BOXHAVEN_API_HOST=api.boxhaven.dev
BOXHAVEN_PREVIEW_BASE_DOMAIN=at.boxhaven.dev
BOXHAVEN_PREVIEW_TARGET_PORT=80
BOXHAVEN_APP_URL=https://app.boxhaven.dev
BOXHAVEN_API_URL=https://api.boxhaven.dev
BETTER_AUTH_URL=https://api.boxhaven.dev/v1/auth
BETTER_AUTH_TRUSTED_ORIGINS=https://app.boxhaven.dev,https://api.boxhaven.dev
BOXHAVEN_BACKEND_CORS_ORIGINS=https://app.boxhaven.dev,https://api.boxhaven.dev
BETTER_AUTH_SECRET=replace-with-a-random-secret-at-least-32-bytes

# Comma-separated emails granted admin access to image management.
BOXHAVEN_ADMIN_EMAILS=

# Stripe billing. Setting STRIPE_SECRET_KEY enables billing, which attaches
# to teams: every personal team gets BOXHAVEN_FREE_MACHINES boxes for free,
# shared teams get BOXHAVEN_TEAM_FREE_MACHINES (subscription-first by
# default), and an active team subscription usage-bills additional boxes per
# box-hour via Stripe Billing Meters. STRIPE_PRICE_ID is the metered price on
# the subscription product, and STRIPE_WEBHOOK_SECRET signs deliveries to
# POST /v1/billing/webhook.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
STRIPE_METER_EVENT_NAME=boxhaven_box_hours
BOXHAVEN_FREE_MACHINES=1
BOXHAVEN_TEAM_FREE_MACHINES=0
# Set to "off" to stop reporting box-hour meter events from this backend.
BOXHAVEN_BILLING_USAGE_REPORTER=

# Resend transactional email. Setting RESEND_API_KEY enables password reset
# and team invitation emails; without it, invite links stay copyable from the
# console and reset emails are skipped with a log line.
RESEND_API_KEY=
BOXHAVEN_EMAIL_FROM=BoxHaven <noreply@boxhaven.dev>

BOXHAVEN_BACKEND_PROVIDER=digitalocean
DIGITALOCEAN_ACCESS_TOKEN=dop_v1_example
DIGITALOCEAN_REGION=nyc3
DIGITALOCEAN_SIZE=s-2vcpu-4gb-amd
DIGITALOCEAN_IMAGE=ubuntu-24-04-x64
DIGITALOCEAN_TAGS=boxhaven
BOXHAVEN_REMOTE_IMAGE=
BOXHAVEN_REMOTE_IMAGE_REF=
BOXHAVEN_REMOTE_IMAGE_NAME=
BOXHAVEN_REMOTE_IMAGE_BUILT_AT=
BOXHAVEN_IMAGE_BUILDER_SHUTDOWN_GRACE_SECONDS=60
DIGITALOCEAN_VPC_UUID=

# Optional Hetzner Cloud provider. Setting HCLOUD_TOKEN enables it alongside
# DigitalOcean; BOXHAVEN_BACKEND_PROVIDER above keeps the default provider.
# HCLOUD_TOKEN=
# HETZNER_LOCATION=nbg1
# BOXHAVEN_REMOTE_IMAGE_HETZNER=

# Image-builder SSH only. Normal user VMs use boxhaven SSH certificates, not
# DigitalOcean account SSH keys.
DIGITALOCEAN_SSH_KEYS=
BOXHAVEN_IMAGE_BUILDER_SSH_PUBLIC_KEY=

BOXHAVEN_BACKUP_RETENTION_DAYS=14
