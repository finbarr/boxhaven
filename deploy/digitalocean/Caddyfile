{
	email {$ACME_EMAIL}
	on_demand_tls {
		ask http://backend:8787/v1/preview/tls-check
	}
}

{$BOXHAVEN_APP_HOST} {
	encode zstd gzip
	reverse_proxy backend:8787
}

{$BOXHAVEN_API_HOST} {
	encode zstd gzip
	reverse_proxy backend:8787
}

{$BOXHAVEN_DOCS_HOST} {
	encode zstd gzip
	root * /srv/docs
	try_files {path} {path}.html =404
	file_server
	handle_errors {
		rewrite * /404.html
		file_server
	}
}

:443 {
	tls {
		on_demand
	}

	@preview_tls_warmup {
		host *.{$BOXHAVEN_PREVIEW_BASE_DOMAIN}
		path /.well-known/boxhaven/preview-tls-warmup
	}
	handle @preview_tls_warmup {
		respond "ok" 200
	}

	@preview host *.{$BOXHAVEN_PREVIEW_BASE_DOMAIN}
	handle @preview {
		rewrite * /v1/preview/proxy/{host}{uri}
		reverse_proxy backend:8787
	}

	respond "not found" 404
}
